{
  "version": 4,
  "configurations": [
    {
      "name": "Windows",
      "includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/build/windows/vcpkg_installed/x64-windows/include"
      ],
      "cStandard": "c17",
      "cppStandard": "c++20",
      "intelliSenseMode": "windows-msvc-x64",
      "configurationProvider": "ms-vscode.cmake-tools"
    },
    {
      "name": "Linux",
      "includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/build/linux-debug/vcpkg_installed/x64-linux/include"
      ],
      "cStandard": "c17",
      "cppStandard": "c++20",
      "intelliSenseMode": "linux-gcc-x64",
      "configurationProvider": "ms-vscode.cmake-tools"
    }
  ]
}
